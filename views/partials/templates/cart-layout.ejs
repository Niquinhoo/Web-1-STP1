<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pediloo - Tu Carrito</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Outfit:wght@500;600;700;800&display=swap" rel="stylesheet">
    
    <link rel="stylesheet" href="/styles/base/reset.css">
    <link rel="stylesheet" href="/styles/base/variables.css">
    <link rel="stylesheet" href="/styles/base/typography.css">
    
    <!-- Atomic CSS for Home components we reuse -->
    <link rel="stylesheet" href="/styles/organisms/home/navbar.css">
    <link rel="stylesheet" href="/styles/molecules/home/search-bar.css">
    <link rel="stylesheet" href="/styles/molecules/home/nav-item.css">
    <link rel="stylesheet" href="/styles/organisms/footer.css">
    
    <!-- Atomic CSS for Cart -->
    <link rel="stylesheet" href="/styles/atoms/cart/action-btn.css">
    <link rel="stylesheet" href="/styles/molecules/cart/cart-item.css">
    <link rel="stylesheet" href="/styles/organisms/cart/cart-container.css">
    <link rel="stylesheet" href="/styles/organisms/cart/cart-list.css">
    <link rel="stylesheet" href="/styles/organisms/cart/cart-summary.css">
    <link rel="stylesheet" href="/styles/templates/cart-layout.css">
</head>
<body class="cart-layout">
    <%- include('../organisms/home/navbar') %>
    
    <main class="main-content">
        <% if (locals.components) { %>
            <% components.forEach(comp => { %>
                <%- include(comp.path, comp.props) %>
            <% }) %>
        <% } %>
    </main>
    
    <%- include('../organisms/footer') %>
</body>
</html>

<input 
    type="<%= locals.type || 'text' %>" 
    class="log-reg-input"
    id="<%= locals.id || locals.name %>" 
    name="<%= locals.name || 'field' %>"
    placeholder="<%= locals.placeholder || 'Escribe aquí...' %>"
    value="<%= locals.value || '' %>"
    autocomplete="<%= locals.autocomplete || 'on' %>"
    <% if (locals.required !== false) { %> required <% } %>
>
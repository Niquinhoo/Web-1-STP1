<%# 
  Parámetros comunes:
  - type: 'text', 'password', 'email'
  - name: nombre del campo
  - placeholder: texto placeholder
  - value: valor inicial
  - autocomplete: atributo autocomplete
  - required: boolean (default true)
%>

<input 
    type="<%= locals.type || 'text' %>" 
    class="log-reg-input"
    id="<%= locals.id || locals.name %>" 
    name="<%= locals.name || 'field' %>"
    placeholder="<%= locals.placeholder || 'Escribe aquí...' %>"
    value="<%= locals.value || '' %>"
    autocomplete="<%= locals.autocomplete || 'on' %>"
    <% if (locals.required !== false) { %> required <% } %>
>
